# --- Ad slots ------------------------------------------------------------
# OFF by default on launch — empty slots render nothing.
#
# During development, preview where slots will sit:
#   PUBLIC_ADS_ENABLED=placeholder
#
# Post-AdSense-approval, render real ads (also requires PUBLIC_ADSENSE_CLIENT
# and a per-slot `slot` id wired into each <AdSlot> usage):
#   PUBLIC_ADS_ENABLED=true
#   PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000
# -------------------------------------------------------------------------

PUBLIC_ADS_ENABLED=
PUBLIC_ADSENSE_CLIENT=

# --- Cloudflare Web Analytics -------------------------------------------
# Cookieless, no consent banner required. Enable the site in CF dashboard →
# Analytics & Logs → Web Analytics, then paste the token here.
# Leave blank to disable.
#   PUBLIC_CF_ANALYTICS_TOKEN=abcdef0123456789...
# -------------------------------------------------------------------------

PUBLIC_CF_ANALYTICS_TOKEN=
