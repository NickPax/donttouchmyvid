---
type Step = { title: string; body: string };
type Props = { steps: Step[]; heading?: string };
const { steps, heading = 'How it works' } = Astro.props;
---
<section id="how-it-works" class="mx-auto max-w-[1320px] px-5 sm:px-8 py-20">
  <div class="grid md:grid-cols-[minmax(0,320px)_1fr] lg:grid-cols-[minmax(0,380px)_1fr] gap-10">
    <div class="min-w-0">
      <div class="section-num">§02 · Procedure</div>
      <h2 class="mt-2 display-2 [overflow-wrap:anywhere] [hyphens:auto]">{heading}.</h2>
      <p class="mt-4 text-sm text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)] max-w-xs">
        Three steps. None of them involve a server.
      </p>
    </div>

    <ol class="grid sm:grid-cols-3 gap-4">
      {steps.map((s, i) => (
        <li class="card p-6 relative">
          <div class="flex items-start justify-between">
            <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)]">Step {String(i + 1).padStart(2, '0')}</span>
            <span class="font-display text-[40px] leading-none text-[var(--color-emerald-dk)]">{String(i + 1)}</span>
          </div>
          <h3 class="font-display text-[26px] mt-3 leading-tight">{s.title}.</h3>
          <p class="mt-3 text-sm leading-relaxed text-[color-mix(in_srgb,var(--color-ink)_82%,transparent)]">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
