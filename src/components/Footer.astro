---
import { GITHUB_REPO, SITE_NAME } from '../lib/constants';

const year = new Date().getFullYear();
const tools = [
  { href: '/compress',      label: 'Compress' },
  { href: '/convert',       label: 'Convert' },
  { href: '/trim',          label: 'Trim' },
  { href: '/mute',          label: 'Mute' },
  { href: '/extract-audio', label: 'Extract audio' },
];

const marqueePhrases = [
  'Your videos.',
  'Your phone.',
  'No exceptions.',
  'Zero uploads.',
  'Zero servers.',
  'Zero frames stored.',
  'Zero watermarks.',
  'Zero tracking.',
];
---
<footer class="mt-24 border-t border-[var(--color-rule)] bg-[var(--color-paper-2)]">
  <!-- Manifesto marquee -->
  <div class="overflow-hidden border-b border-[var(--color-rule)]">
    <div class="marquee py-4">
      {Array.from({ length: 2 }).map(() => (
        <div class="flex items-center shrink-0 pr-10">
          {marqueePhrases.map((phrase) => (
            <span class="flex items-center gap-6 pr-10">
              <span class="font-display text-[38px] md:text-[54px] leading-none">{phrase}</span>
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-emerald-dk)]"></span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="mx-auto max-w-[1320px] px-5 sm:px-8 py-14 grid md:grid-cols-[2fr_1fr_1fr_1fr] gap-10">
    <div>
      <div class="flex items-center gap-2">
        <span class="inline-flex w-7 h-7 items-center justify-center bg-[var(--color-navy-800)] text-[var(--color-paper)] rounded-sm">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
            <rect x="5" y="11" width="14" height="9" />
            <path d="M8 11V8a4 4 0 0 1 8 0v3" />
          </svg>
        </span>
        <span class="font-display text-xl">{SITE_NAME}.</span>
      </div>
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-[color-mix(in_srgb,var(--color-ink)_85%,transparent)]">
        Video tools that actually respect your footage. Your clips never leave your device. We don't upload because we don't have a server.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="chip chip-green">Client-side only</span>
        <span class="chip">No sign-up</span>
        <span class="chip">No watermarks</span>
      </div>
    </div>

    <div>
      <div class="kicker mb-4">Tools</div>
      <ul class="space-y-2.5">
        {tools.map((t) => (
          <li><a href={t.href} class="text-sm hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">{t.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <div class="kicker mb-4">Project</div>
      <ul class="space-y-2.5 text-sm">
        <li><a href="/about" class="hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">About</a></li>
        <li><a href="/about#how-it-works" class="hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">How it works</a></li>
        <li><a href="/about#privacy" class="hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">Privacy promise</a></li>
        <li>
          <a href="https://donttouchmydoc.com" target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">
            Sister site: DontTouchMyDoc
          </a>
        </li>
        <li>
          <a href="https://donttouchmypic.com" target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">
            Sister site: DontTouchMyPic
          </a>
        </li>
        <li class="text-[color-mix(in_srgb,var(--color-ink)_45%,transparent)] cursor-not-allowed">
          Sister site: DontTouchMyScreenshots <span class="text-xs font-mono uppercase tracking-wider">· Coming soon</span>
        </li>
        <li>
          <a href={GITHUB_REPO} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">
            Source on GitHub
            <svg viewBox="0 0 24 24" class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M7 17 17 7M9 7h8v8"/></svg>
          </a>
        </li>
      </ul>
    </div>

    <div>
      <div class="kicker mb-4">Status</div>
      <ul class="space-y-2.5 text-sm font-mono">
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[var(--color-emerald-dk)] rounded-full"></span> all systems cold</li>
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[var(--color-emerald-dk)] rounded-full"></span> 0 servers running</li>
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[var(--color-emerald-dk)] rounded-full"></span> 0 frames stored</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[var(--color-rule)]">
    <div class="mx-auto max-w-[1320px] px-5 sm:px-8 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-xs font-mono text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">
      <span>© {year} {SITE_NAME}.</span>
      <span class="tracking-[0.18em] uppercase">v0.1.0 · donttouchmyvid.com</span>
    </div>
  </div>
</footer>
