---
const path = Astro.url.pathname;
const isActive = (p: string) => (path === p || (p !== '/' && path.startsWith(p)));
const links = [
  { href: '/compress',    label: 'Compress' },
  { href: '/convert',     label: 'Convert' },
  { href: '/trim',        label: 'Trim' },
  { href: '/mute',        label: 'Mute' },
  { href: '/extract-audio', label: 'Extract audio' },
  { href: '/about',       label: 'About' },
];
---
<header class="sticky top-0 z-40 backdrop-blur-sm bg-[color-mix(in_srgb,var(--color-paper)_92%,transparent)] border-b border-[var(--color-rule)]">
  <div class="mx-auto max-w-[1320px] px-5 sm:px-8 py-3.5 flex items-center justify-between gap-6">
    <a href="/" class="group flex items-center gap-2.5" aria-label="DontTouchMyVid home">
      <span class="relative inline-flex items-center justify-center w-7 h-7 rounded-sm bg-[var(--color-navy-800)] text-[var(--color-paper)]">
        <!-- Lock motif — same privacy stamp as the sibling sites -->
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
          <rect x="5" y="11" width="14" height="9" />
          <path d="M8 11V8a4 4 0 0 1 8 0v3" />
        </svg>
        <span class="absolute -bottom-1 -right-1 w-2 h-2 rounded-full bg-[var(--color-emerald)]"></span>
      </span>
      <span class="flex flex-col leading-none">
        <span class="font-mono text-[11px] tracking-[0.22em] uppercase text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">DontTouch</span>
        <span class="font-display text-[19px] -mt-0.5">My&nbsp;Vid.</span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden md:flex items-center gap-1">
      {links.map((l) => (
        <a
          href={l.href}
          aria-current={isActive(l.href) ? 'page' : undefined}
          class:list={[
            'px-2.5 lg:px-3 py-2 rounded-sm text-[13px] font-mono uppercase tracking-[0.06em] lg:tracking-[0.08em] transition-colors',
            isActive(l.href)
              ? 'text-[var(--color-paper)] bg-[var(--color-navy-800)]'
              : 'text-[var(--color-ink)] hover:bg-[color-mix(in_srgb,var(--color-navy)_10%,transparent)]',
          ]}
        >{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <span class="hidden xl:inline-flex chip chip-green">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-emerald-dk)] blink"></span>
        0 bytes uploaded
      </span>

      <!-- Theme toggle. Cycles light <-> dark; persists in localStorage as
           a single key, `theme`. Round, visibly bordered, filled-moon /
           filled-sun icons — the standard "daylight" affordance. The icons
           swap via CSS based on the data-theme attribute on <html> (set
           pre-paint by the init script in BaseLayout). -->
      <button
        id="theme-toggle"
        type="button"
        class="theme-toggle w-9 h-9 shrink-0 inline-flex items-center justify-center rounded-full border-2 border-[var(--color-navy)] bg-[var(--color-paper-2)] text-[var(--color-navy-800)] hover:bg-[var(--color-cream)] hover:border-[var(--color-navy-800)] active:translate-y-[1px] transition-all"
        aria-label="Toggle light / dark mode"
        title="Toggle light / dark mode"
      >
        <!-- Moon: full circle outlined, left half solid-filled. The classic
             half-shaded "contrast" mark used by GNOME / KDE / macOS for the
             same affordance. -->
        <svg class="theme-icon-moon w-[18px] h-[18px]" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3 A 9 9 0 0 0 12 21 Z" fill="currentColor"/>
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/>
        </svg>
        <!-- Sun: outlined circle with eight short ray-stubs around it.
             Spec ported from fxeurope.app — bigger central circle (r=5),
             shorter rays (length 2) so they read as crisp little marks
             rather than long lines. Stroke-linecap default (butt) keeps
             the stubs square-ended. -->
        <svg class="theme-icon-sun w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>

      <button
        id="nav-toggle"
        class="md:hidden w-9 h-9 inline-flex items-center justify-center border border-[var(--color-rule)] rounded-sm"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Toggle navigation"
      >
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="md:hidden hidden border-t border-[var(--color-rule)] bg-[var(--color-cream)]">
    <nav class="mx-auto max-w-[1320px] px-5 py-3 flex flex-col">
      {links.map((l) => (
        <a
          href={l.href}
          aria-current={isActive(l.href) ? 'page' : undefined}
          class:list={[
            'py-2.5 px-2 rounded-sm font-mono text-sm uppercase tracking-[0.08em]',
            isActive(l.href) ? 'bg-[var(--color-navy-800)] text-[var(--color-paper)]' : 'text-[var(--color-ink)]',
          ]}
        >{l.label}</a>
      ))}
    </nav>
  </div>
</header>

<style is:global>
  /* is:global is load-bearing here. Without it, Astro scopes the selector
     to the Header component's data-astro-cid, but [data-theme] lives on
     <html> (in BaseLayout) which doesn't carry that scope-id — so the
     override never matches and BOTH icons stay display:none, leaving an
     empty round button. */
  .theme-icon-sun, .theme-icon-moon { display: none; }
  [data-theme="light"] .theme-icon-moon { display: block; }
  [data-theme="dark"]  .theme-icon-sun  { display: block; }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // Theme toggle: flip data-theme on <html> and persist in localStorage as
  // the single key `theme`. The init script in BaseLayout reads the same
  // key on every page load, so the choice survives navigation.
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch (_) { /* private mode — toggle still works for the session */ }
  });
</script>
